PORT=3000
UPLOAD_DIR=./uploads
OUTPUT_DIR=./outputs
MAX_FILE_SIZE_MB=5000
DEFAULT_CLIP_DURATION=45

# Whisper should be enabled for production viral clipping/captioning.
# Set this to force_off only if you want to disable it for testing.
WHISPER_ENABLED=true
WHISPER_MODEL=large-v3
WHISPER_CLIP_MODEL=large-v3

# FFmpeg rendering knobs.
FFMPEG_PRESET=fast
FFMPEG_CRF=22
FFMPEG_THREADS=0
DEFAULT_EFFECTS_LEVEL=aggressive
FORCE_VERTICAL_OUTPUT=true

# Optional production queue. Requires Redis running on the other laptop.
QUEUE_ENABLED=false
REDIS_URL=redis://127.0.0.1:6379
VIDEO_WORKER_CONCURRENCY=1
QUEUE_JOB_ATTEMPTS=1

# Optional Python AI microservice.
PYTHON_AI_ENABLED=false
PYTHON_AI_URL=http://127.0.0.1:8001
